    "GET /api/v1/context/hvac",
    "GET /api/v1/context/incentives?trade=&state=&utility=&measure=",
    "GET /api/v1/context/climate?state=&county=&county_fips=",
    "GET /api/v1/context/utility-territory?state=&city=&utility=&lat=&lng=&quote_safe=",
    "GET /api/v1/context/utility-territory/resolve?address=",
