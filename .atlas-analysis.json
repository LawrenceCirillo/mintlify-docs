  "keyFeatures": [
    "Quote-safe data quality contracts — every row is marked whether it is safe to use in a quote or context-only",
    "Unified data catalog for solar, HVAC, roofing, finance, and utility datasets",
    "Scoped API keys with per-dataset entitlements (sample, sandbox, production access levels)",
    "Snapshot + delta sync with versioned cursors and webhook notifications on dataset updates",
    "Composite /quote-context endpoint bundling finance, equipment, incentives, labor, permits, and utility resolution",
    "Compare Hub for side-by-side comparisons of finance programs, solar modules/inverters, and HVAC equipment",
    "API Playground for testing endpoints within the dashboard without writing code",
    "Utility territory resolver with Census geocoding, NREL hints, and PostGIS polygon matching",
    "Benchmarks endpoint for statistical distribution context on dealer fees, inverter costs, and interest rates",
    "Source provenance on every record — source URL, review status, last verified date, and confidence level"
  ],
  "publicApiSurface": [
    "GET /api/v1/search?q=&trade=&type=&quote_safe=&limit=",
    "GET /api/v1/catalog/equipment?trade=&category=&manufacturer=&sku=",
    "GET /api/v1/finance/fees?trade=&financier=&payment_type=&term_months=",
    "GET /api/v1/pricing/finance",
    "GET /api/v1/context/finance-products",
    "GET /api/v1/context/finance-eligibility?trade=&state=&measure=",
    "GET /api/v1/hardware/inverters",
